# Database
DATABASE_URL="postgresql://user:password@localhost:5432/cafeorder?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── PhonePe Payment Gateway ─────────────────────────────
# Set PHONEPE_TEST_MODE=true to skip real payments (orders auto-mark as PAID)
PHONEPE_TEST_MODE="true"
# Sandbox (testing): https://api-preprod.phonepe.com/apis/pg-sandbox
# Production:        https://api.phonepe.com/apis/hermes
PHONEPE_BASE_URL="https://api-preprod.phonepe.com/apis/pg-sandbox"
PHONEPE_MERCHANT_ID="PGTESTPAYUAT86"
PHONEPE_SALT_KEY="96434309-7796-489d-8924-ab56988a6076"
PHONEPE_SALT_INDEX="1"

# ─── Cloudinary (image uploads) ──────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── WhatsApp (order notifications) ──────────────────────
# Leave WHATSAPP_PROVIDER empty to log WhatsApp messages to console (dev mode)
# WHATSAPP_PROVIDER="twilio"          # or "meta"
# Twilio WhatsApp
# TWILIO_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# Meta WhatsApp Business Cloud API
# META_WHATSAPP_PHONE_NUMBER_ID=""
# META_WHATSAPP_ACCESS_TOKEN=""
