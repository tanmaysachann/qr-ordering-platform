{
  "name": "qr-ordering-webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:owner": "cross-env PORT=3001 NEXT_DIST_DIR=.next-owner AUTH_URL=http://localhost:3001 NEXT_PUBLIC_APP_URL=http://localhost:3001 next dev --webpack -p 3001",
    "dev:admin": "cross-env PORT=3002 NEXT_DIST_DIR=.next-admin AUTH_URL=http://localhost:3002 NEXT_PUBLIC_APP_URL=http://localhost:3002 next dev --webpack -p 3002",
    "dev:customer": "cross-env PORT=3003 NEXT_DIST_DIR=.next-customer AUTH_URL=http://localhost:3003 NEXT_PUBLIC_APP_URL=http://localhost:3003 next dev --webpack -p 3003",
    "build": "npx prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/adapter-pg-worker": "^6.9.0",
    "@prisma/client": "^7.6.0",
    "@prisma/pg-worker": "^6.9.0",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "prisma": "^7.6.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
